# ── Required ───────────────────────────────────────────────────
# HuggingFace token — needed for Pyannote speaker diarization model.
# Get one at https://huggingface.co/settings/tokens
# Then accept the model licence at https://hf.co/pyannote/speaker-diarization-3.1
HF_TOKEN=your_huggingface_token_here

# ── Optional: pre-download Whisper models ──────────────────────
# Run: python download_model.py
# Defaults to large-v3 and large-v3-turbo if not set.
WHISPER_MODELS_TO_DOWNLOAD=large-v3
